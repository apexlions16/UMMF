{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/apexlions16/UMMF/schemas/mod-manifest.schema.json",
  "title": "UMMF mod manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "version", "replacements"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 3 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gameId": { "type": ["string", "null"] },
        "productName": { "type": ["string", "null"] },
        "minimumFrameworkVersion": { "type": ["string", "null"] }
      }
    },
    "replacements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "match"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["Texture", "Sprite", "Audio", "Subtitle"] },
          "match": { "$ref": "#/$defs/fingerprint" },
          "replacement": { "type": ["string", "null"] },
          "subtitleText": { "type": ["string", "null"] },
          "voice": { "type": ["string", "null"] },
          "stopVoiceWhenHidden": { "type": "boolean", "default": true },
          "delayMilliseconds": { "type": "integer", "minimum": 0, "default": 0 },
          "volume": { "type": "number", "minimum": 0, "maximum": 2, "default": 1 }
        },
        "anyOf": [
          { "required": ["replacement"] },
          { "required": ["subtitleText"] },
          { "required": ["voice"] }
        ]
      }
    }
  },
  "$defs": {
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["Unknown", "Texture", "Sprite", "Audio", "Subtitle"] },
        "stableKey": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "container": { "type": ["string", "null"] },
        "usagePath": { "type": ["string", "null"] },
        "width": { "type": ["integer", "null"], "minimum": 1 },
        "height": { "type": ["integer", "null"], "minimum": 1 },
        "durationSeconds": { "type": ["number", "null"], "minimum": 0 },
        "sampleRate": { "type": ["integer", "null"], "minimum": 1 },
        "channels": { "type": ["integer", "null"], "minimum": 1 },
        "contentHash": { "type": ["string", "null"] },
        "semanticHash": { "type": ["string", "null"] },
        "sourceText": { "type": ["string", "null"] }
      }
    }
  }
}
